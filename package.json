{
  "name": "ios-vocab-app",
  "version": "1.0.0",
  "private": true,
  "description": "离线 iPhone 风格英语背单词 Web App",
  "type": "module",
  "scripts": {
    "build": "node tools/build_static.mjs",
    "serve": "python -m http.server 8000",
    "cap:add:ios": "npm run build && cap add ios",
    "cap:sync:ios": "npm run build && cap sync ios",
    "cap:open:ios": "cap open ios",
    "ios:credentials": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/save_ios_credentials.ps1",
    "ios:cloud-build": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/capgo_build_ios.ps1",
    "ios:unsigned-ipa:mac": "bash tools/build_unsigned_ipa.sh"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@capgo/cli": "^8.3.0"
  }
}
